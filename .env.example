# N8N Webhook Configuration
N8N_BASE_URL=
N8N_TEST_BASE_URL=
N8N_WEBHOOK_ID=
N8N_DISCOVERY_WEBHOOK_URL=

# Supabase Configuration
# Required for client bootstrap plus server API routes.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps Configuration
# Public browser key for client-side maps.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
# Server-side key for geocoding and Places fallback flows.
GOOGLE_MAPS_SERVER_API_KEY=
GOOGLE_MAPS_MAP_ID=
GOOGLE_MAPS_TIMEOUT_MS=5000
GOOGLE_MAPS_MAX_RETRIES=2

# AI / recommendations
GEMINI_API_KEY=
DEFAULT_BRANCH_ID=

# Discovery scoring tuning (server-side)
DISCOVERY_MIN_CONFIDENCE=0.45
DISCOVERY_MIN_SCORE=0.35
DISCOVERY_WEIGHT_DISTANCE=0.2
DISCOVERY_WEIGHT_ETA=0.2
DISCOVERY_WEIGHT_INTENT_RELEVANCE=0.25
DISCOVERY_WEIGHT_PROMO=0.1
DISCOVERY_WEIGHT_RATING=0.15
DISCOVERY_WEIGHT_VALUE=0.1

# Home discovery feature flags (client-side)
NEXT_PUBLIC_HOME_EXPERIMENT_ID=home_discovery_variant_v1
NEXT_PUBLIC_HOME_EXPERIMENT_VARIANTS=rails_assistant,rails_only
NEXT_PUBLIC_HOME_EXPERIMENT_BASELINE_VARIANT=control
NEXT_PUBLIC_HOME_EXPERIMENT_CANARY_PERCENT=20
# Optional override for QA/canary (control|intent_first|rails_only|rails_assistant)
# NEXT_PUBLIC_HOME_EXPERIMENT_FORCE_VARIANT=
NEXT_PUBLIC_HOME_VISUAL_HIERARCHY_V2=true
NEXT_PUBLIC_HOME_INTENT_RAILS=true
NEXT_PUBLIC_HOME_PERSONALIZED_RAILS_V1=true
NEXT_PUBLIC_HOME_STORY_MENUS=true
NEXT_PUBLIC_HOME_FRIENDS_ACTIVITY=true
NEXT_PUBLIC_HOME_DISCOVERY_CHAT=true
NEXT_PUBLIC_HOME_DIETARY_GUARDIAN=true
NEXT_PUBLIC_HOME_FILTERS_SORT_V1=true
NEXT_PUBLIC_HOME_PREDICTIVE_REORDER=true
NEXT_PUBLIC_HOME_PRICE_COMPARE=true
NEXT_PUBLIC_HOME_SEARCH_SUGGESTIONS_V1=true
NEXT_PUBLIC_HOME_STATE_POLISH_V1=true
NEXT_PUBLIC_HOME_SURPRISE_ME=true
# Optional analytics dimension for geo segmentation
# NEXT_PUBLIC_HOME_GEO_BUCKET=

# Suggested presets
# Experiment A (Legacy list vs intent-first rails)
# NEXT_PUBLIC_HOME_EXPERIMENT_ID=home_discovery_exp_a
# NEXT_PUBLIC_HOME_EXPERIMENT_VARIANTS=control,intent_first

# Experiment B (Rails-only vs rails+assistant)
# NEXT_PUBLIC_HOME_EXPERIMENT_ID=home_discovery_exp_b
# NEXT_PUBLIC_HOME_EXPERIMENT_VARIANTS=rails_only,rails_assistant
